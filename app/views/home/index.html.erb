<% content_for :title, "Home · Campus Exchange" %>

<main class="page" role="main">
  <div class="page__container">
    <header class="page__header">
      <h1>
        <% if @user %>
          Hello, <%= @user.name.presence || @user.email %> 👋
        <% else %>
          Welcome to Campus Exchange
        <% end %>
      </h1>
      <p class="page__sub">Peer-to-peer lending and selling for students.</p>
    </header>

    <%# --- START: Updated Content Section --- %>
    <section class="page__content">
      
      <%# Check if the @items variable from your controller has any items %>
      <% if @items.any? %>
        
        <%# We use the CSS classes from the previous suggestion for the grid %>
        <div class="items-container">
          <% @items.each do |item| %>
            <%= link_to item_path(item), class: "item-card-link" do %>
              <%= render "shared/item_card", item: item %>
            <% end %>
          <% end %>
        </div>

      <% else %>
        
        <%# This is your original "empty state" card. It will now only
            show if there are no items available. %>
        <div class="card empty">
          <p>No items are available right now. Why not add your first listing?</p>
        </div>

      <% end %>
    </section>
    <%# --- END: Updated Content Section --- %>
    
  </div>
</main>