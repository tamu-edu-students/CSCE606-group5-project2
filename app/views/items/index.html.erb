<% content_for :title, "Browse Items · Campus Exchange" %>

<main class="page" role="main">
  <div class="page__container">
    <header class="page__header">
      <h1>Browse Items</h1>
      <p class="page__sub">Find what you're looking for.</p>
    </header>

    <%= form_with url: items_path, method: :get, class: "search-filter" do |form| %>
      <div class="filter-group">
        <%# --- CATEGORY DROPDOWN --- %>
        <div class="filter-item">
          <%= form.label :category_id, "Category", class: "filter-label" %>
          <%= form.select :category_id, options_for_select([["All Categories", ""]] + Category.all.map { |c| [c.name, c.id] }, selected: params[:category_id]), class: "filter-select" %>
        </div>

        <%# --- SORT BY DROPDOWN --- %>
        <div class="filter-item">
          <%= form.label :sort_by, "Sort by", class: "filter-label" %>
          <%= form.select :sort_by, options_for_select([["Title", "title"], ["Condition", "condition"], ["Created At", "created_at"]], selected: params[:sort_by]), class: "filter-select" %>
        </div>

        <%# --- ORDER DROPDOWN --- %>
        <div class="filter-item">
          <%= form.label :order, "Order", class: "filter-label" %>
          <%= form.select :order, options_for_select([["Ascending", "asc"], ["Descending", "desc"]], selected: params[:order]), class: "filter-select" %>
        </div>

        <%= form.submit "Apply", class: "filter-item btn btn--primary" %>
      </div>
      <div class="filter-group">
        <div class="filter-item">
          <%= form.text_field :query, 
            value: @search_query, 
            placeholder: "Search for laptops, textbooks, etc...",
            class: "search-bar" %>
          <%= form.submit "Search", class: "btn btn--primary" %>
        </div>
      </div>
    <% end %>

    <%# --- RESULTS SECTION --- %>
    <section class="page__content">
      
      <% if @items.any? %>
        <%# We use the same card grid as the homepage for consistent styling %>
        <div class="items-container">
          <% @items.each do |item| %>
            <%= link_to item_path(item), class: "item-card-link" do %>
              <div class="item-card">
                <div class="item-card-content">
                  <h3 class="item-card-title"><%= item.title %></h3>
                  <p class="item-card-description"><%= truncate(item.description, length: 100) %></p>
                  <div class="item-card-footer">
                    <span class="item-card-condition"><strong>Condition:</strong> <%= item.condition %></span>
                    <% if item.for_sale? %>
                      <span class="item-card-tag sale">For Sale</span>
                    <% else %>
                      <span class="item-card-tag lend">For Lend</span>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

      <% else %>
        <%# This shows if the search had 0 results %>
        <div class="card empty">
          <p>No items found.</p>
        </div>
      <% end %>
    </section>

  </div>
</main>