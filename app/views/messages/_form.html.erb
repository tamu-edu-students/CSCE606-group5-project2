<%= form_with model: [@request, Message.new], local: false, data: { turbo_stream: true }, id: "new_message_form", class: "new-message-form" do |form| %>
    <%= form.text_area :content, rows: 3, class: "message-text-area", placeholder: "Type your message here..." %>
    <%= form.submit "Send Message", class: "message-send btn btn--primary" %>
<% end %>
