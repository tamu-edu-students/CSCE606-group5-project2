<%= form_with model: [@request, Message.new], local: false, data: { turbo_stream: true }, id: "new_message_form" do |form| %>
    <div class="form-group">
        <%= form.label :content, "New Message" %>
        <%= form.text_area :content, rows: 3, class: "form-control", placeholder: "Type your message here..." %>
    </div>
    <%= form.submit "Send Message", class: "btn btn--primary" %>
<% end %>
