<% content_for :title, "Sign in · Campus Exchange" %>

<div class="login-page">
  <section class="login-card" role="region" aria-label="Sign in">
    <header class="login-header">
      <div class="login-logo" aria-hidden="true">🎒</div>
      <h1>Campus Exchange</h1>
      <p>Borrow, lend, or sell items with fellow students</p>
      <span class="badge">Student community</span>
    </header>

    <div class="login-content">
      <div class="login-features" aria-label="Highlights">
        <div class="feature">
          <span class="feature-icon" aria-hidden="true">🔄</span>
          <span class="feature-text">Borrow or lend everyday items</span>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true">💬</span>
          <span class="feature-text">Request and coordinate easily</span>
        </div>
        <div class="feature">
          <span class="feature-icon" aria-hidden="true">🛡️</span>
          <span class="feature-text">Built for your campus community</span>
        </div>
      </div>

      <div class="divider">Sign in to continue</div>

      <%= link_to "/auth/google_oauth2", class: "btn btn--block btn--icon-left btn--google", data: { turbo: false } do %>
        <svg class="btn__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" aria-hidden="true" focusable="false">
          <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12 s5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C33.63,6.053,29.042,4,24,4C12.955,4,4,12.955,4,24 s8.955,20,20,20s20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
          <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,16.108,18.961,14,24,14c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657 C33.63,6.053,29.042,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
          <path fill="#4CAF50" d="M24,44c5.164,0,9.86-1.977,13.409-5.197l-6.192-5.238C29.164,35.81,26.715,36.8,24,36.8 c-5.197,0-9.607-3.317-11.271-7.946l-6.52,5.027C9.472,39.556,16.195,44,24,44z"/>
          <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.793,2.238-2.231,4.166-4.094,5.565c0.001-0.001,0.002-0.001,0.003-0.002 l6.192,5.238C36.94,39.104,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
        </svg>
        <span>Sign in with Google</span>
      <% end %>
    </div>

    <footer class="login-footer">
      <small>By signing in, you agree to our community guidelines.</small>
    </footer>
  </section>
</div>
